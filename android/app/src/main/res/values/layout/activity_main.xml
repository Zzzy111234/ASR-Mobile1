<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:text="ASR Mobile"
            android:textColor="#1A1C1E"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="#E9EDF4"
            android:padding="14dp"
            android:text="Status: Initializing..."
            android:textColor="#43474E"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Model Settings"
            android:textColor="#1A1C1E"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_use_bundled"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="Use Bundled Model"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_select_model"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="Select External Model (.bin)"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_load_model"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="Load Selected Model"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Voice Operations"
            android:textColor="#1A1C1E"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_record"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Record 10s"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_play"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Play Clip"
                android:textAllCaps="false" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_transcribe"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="Transcribe Audio"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_benchmark"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="Run Performance Benchmark"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Transcription"
            android:textColor="#1A1C1E"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_transcript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="#FFFFFF"
            android:hint="Text transcript will display here..."
            android:minLines="3"
            android:padding="12dp"
            android:textColor="#1A1C1E"
            android:textColorHint="#8E9196"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Benchmark Performance"
            android:textColor="#1A1C1E"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_metrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF"
            android:hint="Performance metrics will display here..."
            android:minLines="2"
            android:padding="12dp"
            android:textColor="#1A1C1E"
            android:textColorHint="#8E9196"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
